{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/generate-registry.js --dev && next dev -p 3001",
    "dev:federation": "node scripts/generate-registry.js --dev && FEDERATION_DEV=true next dev -p 3001",
    "build": "env-cmd -f .env.develop node scripts/generate-registry.js && env-cmd -f .env.production next build",
    "build:develop": "env-cmd -f .env.develop node scripts/generate-registry.js && env-cmd -f .env.develop next build",
    "build:staging": "env-cmd -f .env.staging node scripts/generate-registry.js && env-cmd -f .env.staging next build",
    "build:production": "env-cmd -f .env.production node scripts/generate-registry.js && env-cmd -f .env.production next build",
    "promote": "node scripts/promote.js",
    "start": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@hookform/resolvers": "^5.4.0",
    "@measured/puck": "^0.18.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@skybooking/api-client": "*",
    "@skybooking/hooks": "*",
    "@skybooking/puck-config": "*",
    "@skybooking/ui": "*",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "antd": "^5.20.0",
    "dayjs": "^1.11.13",
    "i18next": "^23.15.1",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.454.0",
    "next": "15.1.9",
    "react": "19.2.1",
    "react-cookie": "^7.2.0",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^15.0.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.19",
    "env-cmd": "^11.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5"
  }
}
